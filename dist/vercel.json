{
  "rewrites": [
    {
      "source": "/css/:path*",
      "destination": "/public/css/:path*"
    },
    {
      "source": "/img/:path*",
      "destination": "/public/img/:path*"
    },
    {
      "source": "/js/:path*",
      "destination": "/public/js/:path*"
    }
  ],
  "trailingSlash": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "cleanUrls": false
}