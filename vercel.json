{
  "buildCommand": "node build.js && pip3 install edge-tts --target=dist/api/_python_deps --break-system-packages -q 2>/dev/null && echo 'edge-tts installed to dist/api/_python_deps'",
  "outputDirectory": "dist",
  "trailingSlash": true,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/images/(.*)", "destination": "/img/$1" }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/images/(.*)", "dest": "/img/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "cleanUrls": false
}
